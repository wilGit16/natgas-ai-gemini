//+------------------------------------------------------------------+
//|                                     NatGas_Strategy_v12.3.mq5    |
//|                                     Generated by Gemini AI       |
//|      Base: v12.2 (MTF Momentum Filter added to Strategy 1)       |
//|      Module: M5 Pattern Data Miner (Locked & Continuous)         |
//|      Upgrade: Added 'Strategy' (S1/S2) identifier to CSV Audits  |
//+------------------------------------------------------------------+
#property copyright "Gemini AI"
#property link      ""
#property version   "12.3"

#include <Trade\Trade.mqh>

//--- Strategy Selection Enum
enum ENUM_STRATEGY_ACTIVE
  {
   STRATEGY_ALL = 0,           // Run ALL Strategies (S1, S2)
   STRATEGY_1 = 1,             // Run Strategy 1 Only (M15 Classic v6.8 Trend + M5 Filter)
   STRATEGY_2 = 2              // Run Strategy 2 Only (M5 Compression Breakout + Crossover Anchor)
  };

//--- Miner Timeframe Enum
enum ENUM_MINER_TF
  {
   TF_M5 = PERIOD_M5,      // 5 Minutes
   TF_M15 = PERIOD_M15,    // 15 Minutes
   TF_H1 = PERIOD_H1,      // 1 Hour
   TF_H4 = PERIOD_H4       // 4 Hours
  };

//--- Input Parameters
input group "=== Strategy & Risk ==="
input bool     InpEnableTrading = true;           // Master Toggle: Enable Trading Strategies
input ENUM_STRATEGY_ACTIVE InpStrategyActive = STRATEGY_ALL; // Active Strategy Mode
input int      InpMagic        = 123456;          // Base Magic Number

input group "=== Lot Size & Limits ==="
input double   InpLots         = 0.12;            // Base Lot Size (High Performance Setting)

input group "=== Global Targets & Risk ==="
input int      InpTakeProfit     = 150;           // Global: Take Profit (Points)
input int      InpStopLoss       = 150;           // Global: Stop Loss (Points)
input bool     InpUseTrailing    = true;          // Global: Enable Trailing Stop
input int      InpTrailing_Start = 30;            // Global: Start trailing after X points profit
input int      InpTrailing_Dist  = 20;            // Global: Trail X points behind price

input group "=== Days to Trade ==="
input bool     InpTradeMonday    = true;          // Trade on Monday
input bool     InpTradeTuesday   = true;          // Trade on Tuesday
input bool     InpTradeWednesday = true;          // Trade on Wednesday
input bool     InpTradeThursday  = true;          // Trade on Thursday
input bool     InpTradeFriday    = true;          // Trade on Friday

input group "=== Time Filter Settings ==="
input bool     InpUseTimeFilter = false;           // Restrict trading to specific hours (Recommended)
input int      InpStartHour     = 6;              // Start Trading (Server Hour 0-23)
input int      InpEndHour       = 23;             // Stop Trading (Server Hour 0-23)

input group "=== Friday Gap Protection ==="
input bool     InpUseFridayLogic      = false;    // Enable Friday Anti-Gap Logic (v6.8 Default: FALSE)
input int      InpFridayStopEntryHour = 21;       // Stop New Entries (Hour)
input int      InpFridayCloseAllHour  = 22;       // Close All Positions (Hour)

input group "=== Strategy 1: Trend Momentum (v6.8) ==="
input int      InpTrend_MaxDist_S1 = 5;           // S1: Max allowed distance from EMA20 to enter
input int      InpTrend_MaxDist_EMA50_S1 = 10;    // S1: Max allowed distance from EMA50 to enter
input double   InpMinEmaSpread_S1 = 0.0020;       // S1: MINIMUM EMA SPREAD

// Stoch Settings (S1 M15)
input int      InpStoch_K      = 14;              // S1: Stochastic K Period
input int      InpStoch_D      = 3;               // S1: Stochastic D Period
input int      InpStoch_Slow   = 3;               // S1: Stochastic Slowing
input double   InpStoch_Dist   = 5.0;             // S1: Stochastic Min Spread

input double   InpStoch_Buy_Min  = 20.0;          // S1: Stoch Lower Limit for Buy
input double   InpStoch_Buy_Max  = 80.0;          // S1: Stoch Upper Limit for Buy
input double   InpStoch_Sell_Min = 20.0;          // S1: Stoch Lower Limit for Sell
input double   InpStoch_Sell_Max = 80.0;          // S1: Stoch Upper Limit for Sell

input bool     InpUseRSI_Filter  = true;          // S1: Trade only if RSI agrees with direction
input double   InpRSI_Center     = 50.0;          // S1: Buy > 50, Sell < 50
input int      InpRSI_Period     = 14;            // S1: RSI Period

input group "=== Strategy 2: M5 Compression Breakout ==="
input int      InpPullback_EMA20_S2      = 10;    // S2: Max distance to M5 EMA20 (Price Coiled)
input int      InpMaxEmaSpread_S2        = 15;    // S2: MAXIMUM M5 EMA Spread (Points) -> Demands Squeezed Chop

input group "=== Shared Indicators ==="
input int      InpEMA9_Period  = 9;               // EMA Fast Period (Used by S1 MTF Filter)
input int      InpEMA20_Period = 20;              // EMA Fast Period (Used by S1 & S2)
input int      InpEMA50_Period = 50;              // EMA Slow Period (Used by S1 & S2)
input int      InpEMA200_Period = 200;            // EMA Macro Period (Used by S2)

input group "=== Diagnostics & Logging ==="
input bool     InpLogAllCandles = false;          // Record "NO TRADE" candles to CSV

input group "=== M5 Pattern Data Miner ==="
input bool     InpRunM5DataMiner = false;         // Toggle M5 Event Data Miner
input bool     InpLogOnlyEvents  = false;         // FALSE = Continuous Momentum Tracking

//--- Global Variables
CTrade         trade;
int            handle_EMA20;     // S1 Fast Line
int            handle_EMA50;     // S1 Slow Line
int            handle_EMA200;    // S2 Macro Filter
int            handle_Stoch;
int            handle_RSI;
string         tradeSymbol;
datetime       lastBarTime = 0;
string         csvFilename_S1_Audit = "";
string         csvFilename_S2_Audit = "";

//--- M5 Pattern Data Miner & Strategy 2 Variables
int            handle_EMA9_M5;   // S1 MTF Momentum Filter
int            handle_EMA20_M5;
int            handle_EMA50_M5;
int            handle_Stoch_M5;
int            handle_RSI_M5;
datetime       lastBarTime_M5 = 0;
datetime       lastBarTime_M5_Trade = 0;
string         csvFilename_M5_Miner = "";

//--- Statistics Variables
int    stat_S1_Total = 0; int stat_S1_Wins = 0; int stat_S1_Loss = 0; double stat_S1_PL = 0.0;
int    stat_S2_Total = 0; int stat_S2_Wins = 0; int stat_S2_Loss = 0; double stat_S2_PL = 0.0;

//--- Trade Memory Struct for Synchronous Diagnostics 
struct TradeMemory
  {
   ulong    ticket;
   long     magic;     
   long     type;
   datetime entryTime;
   double   ind1;      // EMA Fast/Anchor
   double   ind2;      // EMA Mid
   double   ind3;      // EMA Slow
   double   stochK;
   double   stochD;
   double   rsi;
   long     tickVol;
   double   sl_level;
   bool     active;
  };
TradeMemory activeTrades[];

//+------------------------------------------------------------------+
//| Helper: Format Double for European Excel (Replaces . with ,)     |
//+------------------------------------------------------------------+
string D2S(double value, int digits)
  {
   string str = DoubleToString(value, digits);
   StringReplace(str, ".", ","); // Convert decimal point to comma for Excel
   return str;
  }

//+------------------------------------------------------------------+
//| Helper: Get Day String                                           |
//+------------------------------------------------------------------+
string GetDayStr(int day_of_week)
  {
   switch(day_of_week)
     {
      case 0: return "Sunday";
      case 1: return "Monday";
      case 2: return "Tuesday";
      case 3: return "Wednesday";
      case 4: return "Thursday";
      case 5: return "Friday";
      case 6: return "Saturday";
     }
   return "Unknown";
  }

//+------------------------------------------------------------------+
//| Expert initialization function                                   |
//+------------------------------------------------------------------+
int OnInit()
  {
   tradeSymbol = _Symbol;
   
   Print(">>> EA INITIALIZING (v12.3) on chart: ", tradeSymbol);
   long hwid = AccountInfoInteger(ACCOUNT_LOGIN);
   ulong msCount = GetMicrosecondCount(); 
   
   // --- CORE INDICATORS & HANDLES (M5 & M15) ---
   // S1 Restored to 20 and 50
   handle_EMA20 = iMA(tradeSymbol, PERIOD_M15, InpEMA20_Period, 0, MODE_EMA, PRICE_CLOSE);
   handle_EMA50 = iMA(tradeSymbol, PERIOD_M15, InpEMA50_Period, 0, MODE_EMA, PRICE_CLOSE);
   handle_EMA200 = iMA(tradeSymbol, PERIOD_M15, InpEMA200_Period, 0, MODE_EMA, PRICE_CLOSE); // Needed for S2 Macro Filter
   handle_Stoch = iStochastic(tradeSymbol, PERIOD_M15, InpStoch_K, InpStoch_D, InpStoch_Slow, MODE_SMA, STO_LOWHIGH);
   handle_RSI   = iRSI(tradeSymbol, PERIOD_M15, InpRSI_Period, PRICE_CLOSE);
   
   // MTF Filters and S2 Data
   handle_EMA9_M5  = iMA(tradeSymbol, PERIOD_M5, InpEMA9_Period, 0, MODE_EMA, PRICE_CLOSE);
   handle_EMA20_M5 = iMA(tradeSymbol, PERIOD_M5, InpEMA20_Period, 0, MODE_EMA, PRICE_CLOSE);
   handle_EMA50_M5 = iMA(tradeSymbol, PERIOD_M5, InpEMA50_Period, 0, MODE_EMA, PRICE_CLOSE);
   handle_Stoch_M5 = iStochastic(tradeSymbol, PERIOD_M5, InpStoch_K, InpStoch_D, InpStoch_Slow, MODE_SMA, STO_LOWHIGH);
   handle_RSI_M5   = iRSI(tradeSymbol, PERIOD_M5, InpRSI_Period, PRICE_CLOSE);

   if(handle_EMA20 == INVALID_HANDLE || handle_EMA50 == INVALID_HANDLE || handle_EMA200 == INVALID_HANDLE || 
      handle_Stoch == INVALID_HANDLE || handle_RSI == INVALID_HANDLE || handle_EMA9_M5 == INVALID_HANDLE ||
      handle_EMA20_M5 == INVALID_HANDLE || handle_EMA50_M5 == INVALID_HANDLE || handle_Stoch_M5 == INVALID_HANDLE)
     {
      Print("Error creating indicator handles.");
      return(INIT_FAILED);
     }

   // --- STRATEGY 1 & 2 AUDIT CSV INITIALIZATION ---
   if(InpEnableTrading)
     {
      // S1 Audit Init
      csvFilename_S1_Audit = "Strategy1_Audit_v12.3_" + IntegerToString(hwid) + ".csv";
      int file1 = FileOpen(csvFilename_S1_Audit, FILE_CSV|FILE_WRITE|FILE_READ|FILE_COMMON|FILE_ANSI, ';');
      if(file1 != INVALID_HANDLE) {
         FileWrite(file1, "Ticket", "Magic", "Strategy", "Type", "Result", "Exit_Reason", "Profit_Loss", "EntryDate", "ExitDate", "EntryDay", "ExitDay", "EntryTime", "ExitTime", "EMA_Fast", "EMA_Mid", "EMA_Slow", "StochK", "StochD", "RSI", "TickVol");
         FileClose(file1);
      }
      
      // S2 Audit Init
      csvFilename_S2_Audit = "Strategy2_Audit_v12.3_" + IntegerToString(hwid) + ".csv";
      int file2 = FileOpen(csvFilename_S2_Audit, FILE_CSV|FILE_WRITE|FILE_READ|FILE_COMMON|FILE_ANSI, ';');
      if(file2 != INVALID_HANDLE) {
         FileWrite(file2, "Ticket", "Magic", "Strategy", "Type", "Result", "Exit_Reason", "Profit_Loss", "EntryDate", "ExitDate", "EntryDay", "ExitDay", "EntryTime", "ExitTime", "EMA20_Anchor", "EMA_Mid", "EMA_Slow", "StochK_M5", "StochD_M5", "RSI_M5", "TickVol");
         FileClose(file2);
      }
     }

   // --- M5 PATTERN DATA MINER INITIALIZATION ---
   if(InpRunM5DataMiner)
     {
      csvFilename_M5_Miner = "M5_Pattern_Miner_" + IntegerToString(hwid) + "_" + IntegerToString(msCount) + ".csv";
      int fileM5 = FileOpen(csvFilename_M5_Miner, FILE_CSV|FILE_WRITE|FILE_READ|FILE_COMMON|FILE_ANSI, ';');
      if(fileM5 != INVALID_HANDLE)
        {
         FileWrite(fileM5, "Date", "Time", "Open", "High", "Low", "Close", "Candle_Points", "Points_Dir", "Cumulative_Points", "EMA_Cross", "EMA20", "EMA50", "Stoch_Cross", "Stoch_K", "Stoch_D", "RSI_Cross", "RSI_Val", "Event_Price");
         FileClose(fileM5);
        }
     }

   trade.SetExpertMagicNumber(InpMagic);
   trade.LogLevel(LOG_LEVEL_NO); 
   return(INIT_SUCCEEDED);
  }

//+------------------------------------------------------------------+
//| Expert deinitialization function                                 |
//+------------------------------------------------------------------+
void OnDeinit(const int reason)
  {
   PrintFormat("Strategy 1: win=%d, loss=%d | Strategy 2: win=%d, loss=%d | Total: win=%d, loss=%d", 
               stat_S1_Wins, stat_S1_Loss, stat_S2_Wins, stat_S2_Loss, 
               (stat_S1_Wins + stat_S2_Wins), (stat_S1_Loss + stat_S2_Loss));
   
   if(handle_EMA20 != INVALID_HANDLE) IndicatorRelease(handle_EMA20); 
   if(handle_EMA50 != INVALID_HANDLE) IndicatorRelease(handle_EMA50); 
   if(handle_EMA200 != INVALID_HANDLE) IndicatorRelease(handle_EMA200);
   if(handle_Stoch != INVALID_HANDLE) IndicatorRelease(handle_Stoch); 
   if(handle_RSI != INVALID_HANDLE) IndicatorRelease(handle_RSI);
   if(handle_EMA9_M5 != INVALID_HANDLE) IndicatorRelease(handle_EMA9_M5); 
   if(handle_EMA20_M5 != INVALID_HANDLE) IndicatorRelease(handle_EMA20_M5); 
   if(handle_EMA50_M5 != INVALID_HANDLE) IndicatorRelease(handle_EMA50_M5);
   if(handle_Stoch_M5 != INVALID_HANDLE) IndicatorRelease(handle_Stoch_M5); 
   if(handle_RSI_M5 != INVALID_HANDLE) IndicatorRelease(handle_RSI_M5);

   Comment("");
  }

//+------------------------------------------------------------------+
//| Helper: M5 Pattern Data Miner Execution Logic                    |
//+------------------------------------------------------------------+
void RunM5PatternMiner()
  {
   if(!InpRunM5DataMiner) return;

   datetime currM5Time = iTime(tradeSymbol, PERIOD_M5, 0);
   if(currM5Time == 0) return; 
   
   if(lastBarTime_M5 == 0)
     {
      lastBarTime_M5 = currM5Time;
      return;
     }
     
   if(currM5Time != lastBarTime_M5)
     {
      // Using static to keep a continuous running total from the start of the EA test
      static long cumulativePoints = 0; 
      
      datetime closedBarTime = iTime(tradeSymbol, PERIOD_M5, 1);
      
      double open[], high[], low[], close[];
      double ema20[], ema50[], stochK[], stochD[], rsi[];
      
      ArraySetAsSeries(open, true); ArraySetAsSeries(high, true);
      ArraySetAsSeries(low, true); ArraySetAsSeries(close, true);
      ArraySetAsSeries(ema20, true); ArraySetAsSeries(ema50, true);
      ArraySetAsSeries(stochK, true); ArraySetAsSeries(stochD, true); ArraySetAsSeries(rsi, true);
      
      if(CopyOpen(tradeSymbol, PERIOD_M5, 1, 3, open) != 3) return;
      if(CopyHigh(tradeSymbol, PERIOD_M5, 1, 3, high) != 3) return;
      if(CopyLow(tradeSymbol, PERIOD_M5, 1, 3, low) != 3) return;
      if(CopyClose(tradeSymbol, PERIOD_M5, 1, 3, close) != 3) return;
      
      if(CopyBuffer(handle_EMA20_M5, 0, 0, 3, ema20) != 3) return;
      if(CopyBuffer(handle_EMA50_M5, 0, 0, 3, ema50) != 3) return;
      if(CopyBuffer(handle_Stoch_M5, 0, 0, 3, stochK) != 3) return;
      if(CopyBuffer(handle_Stoch_M5, 1, 0, 3, stochD) != 3) return;
      if(CopyBuffer(handle_RSI_M5, 0, 0, 3, rsi) != 3) return;

      // 1. Check EMA Cross
      string emaEvent = "None";
      if(ema20[2] <= ema50[2] && ema20[1] > ema50[1]) emaEvent = "Bullish_Cross";
      if(ema20[2] >= ema50[2] && ema20[1] < ema50[1]) emaEvent = "Bearish_Cross";

      // 2. Check Stochastic Cross (Coming strictly from Overbought/Oversold zones)
      string stochEvent = "None";
      if(stochK[2] <= 20 && stochK[2] <= stochD[2] && stochK[1] > stochD[1]) stochEvent = "OS_Buy_Cross";
      if(stochK[2] >= 80 && stochK[2] >= stochD[2] && stochK[1] < stochD[1]) stochEvent = "OB_Sell_Cross";

      // 3. Check RSI Cross 50
      string rsiEvent = "None";
      if(rsi[2] <= 50 && rsi[1] > 50) rsiEvent = "Crossed_Above_50";
      if(rsi[2] >= 50 && rsi[1] < 50) rsiEvent = "Crossed_Below_50";

      // Evaluate if an event occurred
      bool hasEvent = (emaEvent != "None" || stochEvent != "None" || rsiEvent != "None");

      // Write logic based on toggle (now continuous if InpLogOnlyEvents is false)
      if(!InpLogOnlyEvents || hasEvent)
        {
         double point_val = SymbolInfoDouble(tradeSymbol, SYMBOL_POINT);
         
         // Raw size of the candlestick (High - Low)
         long candlePoints = (long)MathRound((high[0] - low[0]) / point_val); 
         
         // Directional logic: + points if Bullish, - points if Bearish
         long dirPoints = (close[0] >= open[0]) ? candlePoints : -candlePoints;
         
         // Add to the Continuous Tracker
         cumulativePoints += dirPoints;
         
         // Format the directional string (e.g. "+38" or "-30")
         string pointsDirStr = (dirPoints >= 0) ? "+" + IntegerToString(dirPoints) : IntegerToString(dirPoints);
         
         MqlDateTime tm;
         TimeToStruct(closedBarTime, tm);
         string dateStr = TimeToString(closedBarTime, TIME_DATE); StringReplace(dateStr, ".", "/");
         string timeStr = TimeToString(closedBarTime, TIME_MINUTES); StringReplace(timeStr, ":", ".");
         
         // At what price? We record the Close price of the candle that confirmed the crossover
         string eventPrice = (hasEvent) ? D2S(close[0], 4) : "";
         
         int file = FileOpen(csvFilename_M5_Miner, FILE_CSV|FILE_WRITE|FILE_READ|FILE_COMMON|FILE_ANSI, ';');
         if(file != INVALID_HANDLE)
           {
            FileSeek(file, 0, SEEK_END);
            // Write Continuous Math with EMA20 and EMA50 values added
            FileWrite(file, dateStr, timeStr, D2S(open[0], 4), D2S(high[0], 4), D2S(low[0], 4), D2S(close[0], 4), 
                      IntegerToString(candlePoints), pointsDirStr, IntegerToString(cumulativePoints), 
                      emaEvent, D2S(ema20[1], 4), D2S(ema50[1], 4), stochEvent, D2S(stochK[1], 2), D2S(stochD[1], 2), rsiEvent, D2S(rsi[1], 2), eventPrice);
            FileClose(file);
           }
        }
        
      lastBarTime_M5 = currM5Time;
     }
  }

//+------------------------------------------------------------------+
//| Helper: Check Trading Time & Days                                |
//+------------------------------------------------------------------+
bool IsTradingTime()
  {
   datetime currentTime = TimeCurrent();
   MqlDateTime tm;
   TimeToStruct(currentTime, tm);
   
   if(tm.day_of_week == 1 && !InpTradeMonday) return(false);
   if(tm.day_of_week == 2 && !InpTradeTuesday) return(false);
   if(tm.day_of_week == 3 && !InpTradeWednesday) return(false);
   if(tm.day_of_week == 4 && !InpTradeThursday) return(false);
   if(tm.day_of_week == 5 && !InpTradeFriday) return(false);
   
   if(InpUseFridayLogic && tm.day_of_week == 5 && tm.hour >= InpFridayStopEntryHour) return(false);
     
   if(!InpUseTimeFilter) return(true);
   if(tm.hour >= InpStartHour && tm.hour < InpEndHour) return(true);
   
   return(false);
  }

//+------------------------------------------------------------------+
//| Helper: Friday Anti-Gap Protection                               |
//+------------------------------------------------------------------+
void CheckFridayClose()
  {
   if(!InpUseFridayLogic) return;
   
   MqlDateTime tm;
   TimeToStruct(TimeCurrent(), tm);
   
   if(tm.day_of_week == 5 && tm.hour >= InpFridayCloseAllHour)
     {
      for(int i = PositionsTotal() - 1; i >= 0; i--)
        {
         ulong ticket = PositionGetTicket(i);
         if(PositionSelectByTicket(ticket))
           {
            if(PositionGetString(POSITION_SYMBOL) == tradeSymbol) trade.PositionClose(ticket);
           }
        }
     }
  }

//+------------------------------------------------------------------+
//| Helper: Synchronous Diagnostic CSV Logger (w/ Exit Reasons)      |
//+------------------------------------------------------------------+
bool IsTracked(ulong ticket)
  {
   for(int i = 0; i < ArraySize(activeTrades); i++)
     {
      if(activeTrades[i].active && activeTrades[i].ticket == ticket) return true;
     }
   return false;
  }

void TrackNewTrade(ulong ticket, long magic, long type, datetime entryTime, double ind1, double ind2, double ind3, double stochK, double stochD, double rsi, long tickVol, double sl_level)
  {
   int size = ArraySize(activeTrades);
   for(int i = 0; i < size; i++)
     {
      if(!activeTrades[i].active)
        {
         activeTrades[i].ticket = ticket;
         activeTrades[i].magic = magic;
         activeTrades[i].type = type; activeTrades[i].entryTime = entryTime;
         activeTrades[i].ind1 = ind1; activeTrades[i].ind2 = ind2; activeTrades[i].ind3 = ind3; 
         activeTrades[i].stochK = stochK; activeTrades[i].stochD = stochD; 
         activeTrades[i].rsi = rsi; activeTrades[i].tickVol = tickVol;
         activeTrades[i].sl_level = sl_level;
         activeTrades[i].active = true;
         return;
        }
     }
   ArrayResize(activeTrades, size + 1);
   activeTrades[size].ticket = ticket; 
   activeTrades[size].magic = magic;
   activeTrades[size].type = type; 
   activeTrades[size].entryTime = entryTime;
   activeTrades[size].ind1 = ind1; activeTrades[size].ind2 = ind2; activeTrades[size].ind3 = ind3; 
   activeTrades[size].stochK = stochK; activeTrades[size].stochD = stochD; 
   activeTrades[size].rsi = rsi; activeTrades[size].tickVol = tickVol;
   activeTrades[size].sl_level = sl_level;
   activeTrades[size].active = true;
  }

void UpdateTradeSL(ulong ticket, double newSL)
  {
   for(int i = 0; i < ArraySize(activeTrades); i++)
     {
      if(activeTrades[i].active && activeTrades[i].ticket == ticket)
        {
         activeTrades[i].sl_level = newSL;
         break;
        }
     }
  }

bool ProcessClosedTrade(TradeMemory &mem)
  {
   HistorySelect(0, TimeCurrent());
   double profit = 0;
   datetime exitTime = 0; bool found = false;
   string exitReason = "Unknown";

   int total = HistoryDealsTotal();
   for(int i = total - 1; i >= 0; i--)
     {
      ulong dealTicket = HistoryDealGetTicket(i);
      if(HistoryDealGetInteger(dealTicket, DEAL_POSITION_ID) == mem.ticket)
        {
         if(HistoryDealGetInteger(dealTicket, DEAL_ENTRY) == DEAL_ENTRY_OUT)
           {
            profit += HistoryDealGetDouble(dealTicket, DEAL_PROFIT) + HistoryDealGetDouble(dealTicket, DEAL_SWAP) + HistoryDealGetDouble(dealTicket, DEAL_COMMISSION);
            exitTime = (datetime)HistoryDealGetInteger(dealTicket, DEAL_TIME);
            
            long reasonCode = HistoryDealGetInteger(dealTicket, DEAL_REASON);
            if(reasonCode == DEAL_REASON_SL)
              {
               double openPrice = HistoryDealGetDouble(dealTicket, DEAL_PRICE);
               bool isTrailing = false;
               
               if(mem.type == POSITION_TYPE_BUY && mem.sl_level > openPrice) isTrailing = true;
               if(mem.type == POSITION_TYPE_SELL && mem.sl_level < openPrice && mem.sl_level > 0) isTrailing = true;
               
               if(isTrailing || profit > 0) exitReason = "Trailing Stop";
               else exitReason = "Stop Loss";
              }
            else if(reasonCode == DEAL_REASON_TP) exitReason = "Take Profit";
            else if(reasonCode == DEAL_REASON_CLIENT)
              {
               MqlDateTime tm; TimeToStruct(exitTime, tm);
               if(InpUseFridayLogic && tm.day_of_week == 5 && tm.hour >= InpFridayCloseAllHour) exitReason = "Friday Close";
               else exitReason = "Manual/Logic Close";
              }
            
            found = true; break;
           }
        }
     }

   if(!found) return false;
   string resultStr = (profit > 0) ? "Win" : "Loss";
   string typeStr = (mem.type == POSITION_TYPE_BUY) ? "Buy" : "Sell";
   string stratStr = "Unknown";
   
   string targetAuditFile = "";
   if(mem.magic == InpMagic + 1)
     {
      stratStr = "S1";
      stat_S1_Total++;
      if(profit > 0) stat_S1_Wins++; else stat_S1_Loss++;
      stat_S1_PL += profit;
      targetAuditFile = csvFilename_S1_Audit;
     }
   else if(mem.magic == InpMagic + 2)
     {
      stratStr = "S2";
      stat_S2_Total++;
      if(profit > 0) stat_S2_Wins++; else stat_S2_Loss++;
      stat_S2_PL += profit;
      targetAuditFile = csvFilename_S2_Audit;
     }
   
   MqlDateTime inTm; TimeToStruct(mem.entryTime, inTm); string inDay = GetDayStr(inTm.day_of_week);
   string inDate = TimeToString(mem.entryTime, TIME_DATE); StringReplace(inDate, ".", "/");
   string inTime = TimeToString(mem.entryTime, TIME_MINUTES); StringReplace(inTime, ":", ".");

   MqlDateTime outTm; TimeToStruct(exitTime, outTm);
   string outDay = GetDayStr(outTm.day_of_week);
   string outDate = TimeToString(exitTime, TIME_DATE); StringReplace(outDate, ".", "/");
   string outTime = TimeToString(exitTime, TIME_MINUTES); StringReplace(outTime, ":", ".");
   
   if(targetAuditFile != "")
     {
      int file = FileOpen(targetAuditFile, FILE_CSV|FILE_WRITE|FILE_READ|FILE_COMMON|FILE_ANSI, ';');
      if(file != INVALID_HANDLE)
        {
         FileSeek(file, 0, SEEK_END);
         FileWrite(file, IntegerToString(mem.ticket), IntegerToString(mem.magic), stratStr, typeStr, resultStr, exitReason, D2S(profit, 2), 
                   inDate, outDate, inDay, outDay, inTime, outTime,
                   D2S(mem.ind1, 4), D2S(mem.ind2, 4), D2S(mem.ind3, 4), D2S(mem.stochK, 2), D2S(mem.stochD, 2), D2S(mem.rsi, 2), IntegerToString(mem.tickVol));
         FileClose(file);
        }
     }
   return true;
  }

//+------------------------------------------------------------------+
//| Helper: Consolidated Trailing Stops for All Strategies           |
//+------------------------------------------------------------------+
void CheckTrailingStops(double point, int digits)
{
   if(!InpUseTrailing) return;

   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(PositionSelectByTicket(PositionGetTicket(i)))
      {
         long magic = PositionGetInteger(POSITION_MAGIC);
         
         if(PositionGetString(POSITION_SYMBOL) == tradeSymbol && (magic == InpMagic + 1 || magic == InpMagic + 2))
         {
            ulong ticket = PositionGetInteger(POSITION_TICKET);
            long type = PositionGetInteger(POSITION_TYPE);
            double openPrice = PositionGetDouble(POSITION_PRICE_OPEN);
            double currentSL = PositionGetDouble(POSITION_SL);
            double currentTP = PositionGetDouble(POSITION_TP);
            
            if(type == POSITION_TYPE_BUY)
            {
               double bid = SymbolInfoDouble(tradeSymbol, SYMBOL_BID);
               if((bid - openPrice) >= InpTrailing_Start * point)
               {
                  double newSL = NormalizeDouble(bid - (InpTrailing_Dist * point), digits);
                  // v6.8 Logic: Fearless trail without the "+10 point jump" requirement
                  if(newSL > currentSL || currentSL == 0) 
                    {
                     trade.PositionModify(ticket, newSL, currentTP);
                     UpdateTradeSL(ticket, newSL);
                    }
               }
            }
            else if(type == POSITION_TYPE_SELL)
            {
               double ask = SymbolInfoDouble(tradeSymbol, SYMBOL_ASK);
               if((openPrice - ask) >= InpTrailing_Start * point)
               {
                  double newSL = NormalizeDouble(ask + (InpTrailing_Dist * point), digits);
                  // v6.8 Logic: Fearless trail without the "+10 point jump" requirement
                  if(newSL < currentSL || currentSL == 0) 
                    {
                     trade.PositionModify(ticket, newSL, currentTP);
                     UpdateTradeSL(ticket, newSL);
                    }
               }
            }
         }
      }
   }
}

//+------------------------------------------------------------------+
//| Expert tick function                                             |
//+------------------------------------------------------------------+
void OnTick()
  {
   // --- 0. Trigger M5 Data Miner ---
   RunM5PatternMiner();
   if(!InpEnableTrading) return; 
   
   // --- 1. Friday Anti-Gap Protection ---
   CheckFridayClose();
   
   // --- 2. Get Core Indicator Data (M15) ---
   double ema20[], ema50[], ema200[], stochK[], stochD[], rsiVal[];
   long tickVol[];
   
   ArraySetAsSeries(ema20, true); ArraySetAsSeries(ema50, true); ArraySetAsSeries(ema200, true);
   ArraySetAsSeries(stochK, true); ArraySetAsSeries(stochD, true);
   ArraySetAsSeries(rsiVal, true);
   ArraySetAsSeries(tickVol, true);

   if(CopyBuffer(handle_EMA20, 0, 0, 4, ema20) != 4) return;
   if(CopyBuffer(handle_EMA50, 0, 0, 4, ema50) != 4) return;
   if(CopyBuffer(handle_EMA200, 0, 0, 4, ema200) != 4) return;
   if(CopyBuffer(handle_Stoch, 0, 0, 4, stochK) != 4) return;
   if(CopyBuffer(handle_Stoch, 1, 0, 4, stochD) != 4) return; 
   if(CopyBuffer(handle_RSI, 0, 0, 2, rsiVal) != 2) return;
   if(CopyTickVolume(tradeSymbol, PERIOD_M15, 0, 2, tickVol) != 2) return;

   double bid = SymbolInfoDouble(tradeSymbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(tradeSymbol, SYMBOL_ASK);
   double point = SymbolInfoDouble(tradeSymbol, SYMBOL_POINT);
   int digits = (int)SymbolInfoInteger(tradeSymbol, SYMBOL_DIGITS);

   double currEMA20 = ema20[0]; double currEMA50 = ema50[0]; double currEMA200 = ema200[0];
   double currK = stochK[0];    double currD = stochD[0];
   double currRSI = rsiVal[0];
   long currTickVol = tickVol[0];
   
   double distStoch = MathAbs(currK - currD);
   double distPrice_EMA20_S1 = MathAbs(bid - currEMA20) / point; 
   double distPrice_EMA50_S1 = MathAbs(bid - currEMA50) / point; 
   
   // --- SYNCHRONOUS DIAGNOSTIC TRACKER (Exit Check) ---
   for(int i = 0; i < ArraySize(activeTrades); i++)
     {
      if(activeTrades[i].active)
        {
         if(!PositionSelectByTicket(activeTrades[i].ticket))
           {
            if(ProcessClosedTrade(activeTrades[i])) activeTrades[i].active = false;
           }
        }
     }

   datetime currBarTime = iTime(tradeSymbol, PERIOD_M15, 0);
   bool isNewBar = (currBarTime != lastBarTime);
     
   // --- EVERY TICK MANAGEMENT ---
   CheckTrailingStops(point, digits);

   bool runStrat1 = (InpStrategyActive == STRATEGY_ALL || InpStrategyActive == STRATEGY_1);
   bool runStrat2 = (InpStrategyActive == STRATEGY_ALL || InpStrategyActive == STRATEGY_2);
   
   bool isS1Open = false; bool isS2Open = false;

   // Check Active Positions
   for(int i = PositionsTotal() - 1; i >= 0; i--)
     {
      ulong ticket = PositionGetTicket(i);
      if(PositionSelectByTicket(ticket))
        {
         if(PositionGetString(POSITION_SYMBOL) == tradeSymbol)
           {
            long magic = PositionGetInteger(POSITION_MAGIC);
            
            if(magic == InpMagic + 1) 
              {
               isS1Open = true;
               // S1 Logs: Fast=EMA20, Mid=EMA50, Slow=0
               if(!IsTracked(ticket)) TrackNewTrade(ticket, magic, PositionGetInteger(POSITION_TYPE), TimeCurrent(), currEMA20, currEMA50, 0.0, currK, currD, currRSI, currTickVol, PositionGetDouble(POSITION_SL));
              }
            else if(magic == InpMagic + 2) 
              {
               isS2Open = true;
               if(!IsTracked(ticket))
                 {
                  double tk_sK[1], tk_sD[1], tk_e20[], tk_e50[], tk_rsiM5[1];
                  ArraySetAsSeries(tk_e20, true); ArraySetAsSeries(tk_e50, true);
                  CopyBuffer(handle_Stoch_M5, 0, 0, 1, tk_sK); CopyBuffer(handle_Stoch_M5, 1, 0, 1, tk_sD);
                  CopyBuffer(handle_EMA20_M5, 0, 0, 100, tk_e20); CopyBuffer(handle_EMA50_M5, 0, 0, 100, tk_e50);
                  CopyBuffer(handle_RSI_M5, 0, 0, 1, tk_rsiM5);
                  
                  double logAnchor = 0.0;
                  if(tk_e20[0] > tk_e50[0]) {
                     for(int j=1; j<100; j++) { if(tk_e20[j] <= tk_e50[j]) { logAnchor = tk_e20[j-1]; break; } }
                  } else {
                     for(int j=1; j<100; j++) { if(tk_e20[j] >= tk_e50[j]) { logAnchor = tk_e20[j-1]; break; } }
                  }
                  
                  // S2 Logs: Fast=EMA20_Anchor, Mid=EMA20, Slow=EMA50
                  TrackNewTrade(ticket, magic, PositionGetInteger(POSITION_TYPE), TimeCurrent(), logAnchor, tk_e20[0], tk_e50[0], tk_sK[0], tk_sD[0], tk_rsiM5[0], currTickVol, PositionGetDouble(POSITION_SL));
                 }
              }
           }
        }
     }
   
   if(!IsTradingTime()) return;
   
   // =========================================================================================
   // STRATEGY 1: STOCHASTIC TREND MOMENTUM (Classic v6.8 + M5 MTF Filter)
   // =========================================================================================
   if(runStrat1 && !isS1Open)
     {
      // --- Fetch MTF (Multi-Timeframe) M5 Momentum data ---
      double m5_e9[1], m5_e20[1];
      CopyBuffer(handle_EMA9_M5, 0, 0, 1, m5_e9);
      CopyBuffer(handle_EMA20_M5, 0, 0, 1, m5_e20);
      bool isM5MomUp = (m5_e9[0] > m5_e20[0]);
      bool isM5MomDown = (m5_e9[0] < m5_e20[0]);

      // Core Trend: EMA 20 vs EMA 50
      bool isTrendBuy = (ema20[1] > ema50[1]);
      bool isTrendSell = (ema50[1] > ema20[1]);
      
      bool isRsiBuyOK = (!InpUseRSI_Filter || currRSI > InpRSI_Center);
      bool isRsiSellOK = (!InpUseRSI_Filter || currRSI < InpRSI_Center);
      
      // Pullback Zone: Near EMA 20 OR EMA 50
      bool isNearEMA20 = (distPrice_EMA20_S1 <= InpTrend_MaxDist_S1);
      bool isNearEMA50 = (distPrice_EMA50_S1 <= InpTrend_MaxDist_EMA50_S1);
      bool isDistanceOK = (isNearEMA20 || isNearEMA50);
      
      // Spread Filter (Raw price format as in v6.8)
      double currentEmaSpread = MathAbs(currEMA20 - currEMA50);
      bool isSpreadOK = (currentEmaSpread >= InpMinEmaSpread_S1);
      
      string stratCommentBuy = isNearEMA20 ? "S1 Buy(ema20)" : "S1 Buy(ema50)";
      string stratCommentSell = isNearEMA20 ? "S1 Sell(ema20)" : "S1 Sell(ema50)";
      
      // S1 BUY Logic (Now requires M5 momentum to be UP)
      if(isTrendBuy && isDistanceOK && bid > currEMA50 && isRsiBuyOK && isSpreadOK && isM5MomUp)
        {
         if(currK > InpStoch_Buy_Min && currD > InpStoch_Buy_Min && currK < InpStoch_Buy_Max && currD < InpStoch_Buy_Max && currK > currD && distStoch >= InpStoch_Dist)
           {
            double sl = NormalizeDouble(ask - (InpStopLoss * point), digits);
            double tp = NormalizeDouble(ask + (InpTakeProfit * point), digits); 
            trade.SetExpertMagicNumber(InpMagic + 1);
            if(trade.Buy(InpLots, tradeSymbol, ask, sl, tp, stratCommentBuy))
              {
               PrintFormat("📈 [OPEN S1 BUY] Price: %.3f | EMA20(M15): %.3f | EMA50(M15): %.3f | Gap: %.1f pts | DistE20: %.1f pts | DistE50: %.1f pts | RSI(M15): %.1f | M5(9>20): %.3f > %.3f", 
                           ask, currEMA20, currEMA50, currentEmaSpread / point, MathAbs(ask - currEMA20) / point, MathAbs(ask - currEMA50) / point, currRSI, m5_e9[0], m5_e20[0]);
               isS1Open = true; 
              }
           }
        }
      // S1 SELL Logic (Now requires M5 momentum to be DOWN)
      else if(isTrendSell && isDistanceOK && bid < currEMA50 && isRsiSellOK && isSpreadOK && isM5MomDown)
        {
         if(currK > InpStoch_Sell_Min && currD > InpStoch_Sell_Min && currK < InpStoch_Sell_Max && currD < InpStoch_Sell_Max && currD > currK && distStoch >= InpStoch_Dist)
           {
            double sl = NormalizeDouble(bid + (InpStopLoss * point), digits);
            double tp = NormalizeDouble(bid - (InpTakeProfit * point), digits);
            trade.SetExpertMagicNumber(InpMagic + 1);
            if(trade.Sell(InpLots, tradeSymbol, bid, sl, tp, stratCommentSell))
              {
               PrintFormat("📉 [OPEN S1 SELL] Price: %.3f | EMA20(M15): %.3f | EMA50(M15): %.3f | Gap: %.1f pts | DistE20: %.1f pts | DistE50: %.1f pts | RSI(M15): %.1f | M5(9<20): %.3f < %.3f", 
                           bid, currEMA20, currEMA50, currentEmaSpread / point, MathAbs(bid - currEMA20) / point, MathAbs(bid - currEMA50) / point, currRSI, m5_e9[0], m5_e20[0]);
               isS1Open = true;
              }
           }
        }
     }

   // =========================================================================================
   // STRATEGY 2: M5 COMPRESSION BREAKOUT
   // =========================================================================================
   datetime currBarTime_M5 = iTime(tradeSymbol, PERIOD_M5, 0);
   bool isNewBar_M5 = (currBarTime_M5 != lastBarTime_M5_Trade);
   
   if(runStrat2 && isNewBar_M5 && lastBarTime_M5_Trade != 0)
     {
      double sK[], sD[], e20M5[], e50M5[], e20M5_hist[], e50M5_hist[], rsiM5[];
      ArraySetAsSeries(sK, true); ArraySetAsSeries(sD, true); 
      ArraySetAsSeries(e20M5, true); ArraySetAsSeries(e50M5, true);
      ArraySetAsSeries(e20M5_hist, true); ArraySetAsSeries(e50M5_hist, true);
      ArraySetAsSeries(rsiM5, true);
      
      // Get 100 candles of history for the crossover anchor calculation
      if(CopyBuffer(handle_Stoch_M5, 0, 0, 3, sK) == 3 &&
         CopyBuffer(handle_Stoch_M5, 1, 0, 3, sD) == 3 &&
         CopyBuffer(handle_EMA20_M5, 0, 0, 3, e20M5) == 3 &&
         CopyBuffer(handle_EMA50_M5, 0, 0, 3, e50M5) == 3 &&
         CopyBuffer(handle_EMA20_M5, 0, 0, 100, e20M5_hist) == 100 &&
         CopyBuffer(handle_EMA50_M5, 0, 0, 100, e50M5_hist) == 100 &&
         CopyBuffer(handle_RSI_M5, 0, 0, 3, rsiM5) == 3)
        {
         double curE20 = e20M5[1]; // Evaluated on current closed candle
         double curE50 = e50M5[1];
         double curK = sK[1];
         double curD = sD[1];
         double prevK = sK[2]; // Previous closed candle for crossover detection
         double prevD = sD[2];
         double curRSI_M5 = rsiM5[1]; // M5 RSI for logging
         
         double distE20_Buy = MathAbs(ask - curE20) / point;
         double distE50_Buy = MathAbs(ask - curE50) / point;
         double distE20_Sell = MathAbs(bid - curE20) / point;
         double distE50_Sell = MathAbs(bid - curE50) / point;
         
         double emaSpreadPts = MathAbs(curE20 - curE50) / point; // Converted to Points
         double stochSpread = MathAbs(curK - curD);
         
         // Evaluate M15 Institutional Trend for S2 Filter (Using S1's already loaded M15 buffers)
         bool isMacroUptrend = (ema50[1] > ema200[1]);
         bool isMacroDowntrend = (ema50[1] < ema200[1]);
         
         bool isUptrend = (curE20 > curE50); 
         bool isDowntrend = (curE20 < curE50); 
         bool isSafeBuy = (bid > curE50); 
         bool isSafeSell = (bid < curE50); 
         bool isCrossUp = (prevK <= prevD && curK > curD); // THE SNIPER TRIGGER
         bool isCrossDown = (prevK >= prevD && curK < curD); // THE SNIPER TRIGGER
         bool isBuyZoneOK = (curK < 80 && curD < 80); // Buy anywhere EXCEPT Overbought
         bool isSellZoneOK = (curK > 20 && curD > 20); // Sell anywhere EXCEPT Oversold
           
         // --- STRATEGY 2: COMPRESSION BREAKOUT (Maximum Spread + CROSSOVER ANCHOR + MACRO FILTER) ---
         if(!isS2Open)
           {
            bool isPullbackOK_S2 = (distE20_Buy <= InpPullback_EMA20_S2) || (distE20_Sell <= InpPullback_EMA20_S2); // Tight Pullback to M5 EMA 20 (Coiled)
            bool isSpreadOK_S2 = (emaSpreadPts <= InpMaxEmaSpread_S2); // MAXIMUM Spread (EMAs Squeezed)
            
            // The Crossover Anchor Filter (Peak Tracking)
            double anchorEma20 = 0.0;
            int trendAge = -1;
            
            if(isUptrend) {
               for(int j=1; j<100; j++) {
                  if(e20M5_hist[j] <= e50M5_hist[j]) { // Found exact moment it crossed UP
                     trendAge = j;
                     anchorEma20 = e20M5_hist[j-1]; // Value of EMA 20 at the cross
                     break;
                  }
               }
            } else if(isDowntrend) {
               for(int j=1; j<100; j++) {
                  if(e20M5_hist[j] >= e50M5_hist[j]) { // Found exact moment it crossed DOWN
                     trendAge = j;
                     anchorEma20 = e20M5_hist[j-1]; // Value of EMA 20 at the cross
                     break;
                  }
               }
            }
            
            bool isAnchorUp_S2 = (trendAge != -1 && curE20 > anchorEma20);   // Current EMA20 is cleanly pushing ABOVE its origin
            bool isAnchorDown_S2 = (trendAge != -1 && curE20 < anchorEma20); // Current EMA20 is cleanly pushing BELOW its origin

            // S2 Buy (Now requires M15 Institutional Uptrend)
            if(isUptrend && isSpreadOK_S2 && isAnchorUp_S2 && isMacroUptrend && isSafeBuy && isPullbackOK_S2)
              {
               if(isBuyZoneOK && isCrossUp && stochSpread >= 5.0)
                 {
                  double sl = NormalizeDouble(ask - (InpStopLoss * point), digits);
                  double tp = NormalizeDouble(ask + (InpTakeProfit * point), digits); 
                  trade.SetExpertMagicNumber(InpMagic + 2);
                  if(trade.Buy(InpLots, tradeSymbol, ask, sl, tp, "S2 M5 Breakout Buy"))
                    {
                     PrintFormat("📈 [OPEN S2 BUY] Price: %.3f | EMA20(M5): %.3f | EMA50(M5): %.3f | Gap: %.1f pts | DistE20: %.1f pts | DistE50: %.1f pts | RSI(M5): %.1f", 
                                 ask, curE20, curE50, emaSpreadPts, distE20_Buy, distE50_Buy, curRSI_M5);
                     isS2Open = true; 
                    }
                 }
              }

            // S2 Sell (Now requires M15 Institutional Downtrend)
            if(!isS2Open && isDowntrend && isSpreadOK_S2 && isAnchorDown_S2 && isMacroDowntrend && isSafeSell && isPullbackOK_S2)
              {
               if(isSellZoneOK && isCrossDown && stochSpread >= 5.0)
                 {
                  double sl = NormalizeDouble(bid + (InpStopLoss * point), digits);
                  double tp = NormalizeDouble(bid - (InpTakeProfit * point), digits);
                  trade.SetExpertMagicNumber(InpMagic + 2);
                  if(trade.Sell(InpLots, tradeSymbol, bid, sl, tp, "S2 M5 Breakout Sell"))
                    {
                     PrintFormat("📉 [OPEN S2 SELL] Price: %.3f | EMA20(M5): %.3f | EMA50(M5): %.3f | Gap: %.1f pts | DistE20: %.1f pts | DistE50: %.1f pts | RSI(M5): %.1f", 
                                 bid, curE20, curE50, emaSpreadPts, distE20_Sell, distE50_Sell, curRSI_M5);
                     isS2Open = true;
                    }
                 }
              }
           }
        }
     }
      
   if(currBarTime != lastBarTime) lastBarTime = currBarTime;
   if(currBarTime_M5 != lastBarTime_M5_Trade) lastBarTime_M5_Trade = currBarTime_M5;
  }
